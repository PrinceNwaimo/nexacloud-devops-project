apiVersion: apps/v1
kind: Deployment
metadata:
  name: nexacloud-api
spec:
  replicas: 1
  selector:
    matchLabels:
      app: nexacloud-api
  template:
    metadata:
      labels:
        app: nexacloud-api
    spec:
      containers:
            - name: api
        image: nexacloud-api:latest
        imagePullPolicy: Never
        ports:
                - containerPort: 3000
        resources:
          limits:
            memory: "256Mi"
            cpu: "500m"
          requests:
            memory: "128Mi"
            cpu: "250m"
*k8s/service.yaml*
apiVersion: v1
kind: Service
metadata:
  name: nexacloud-api-service
spec:
  type: NodePort
  selector:
    app: nexacloud-api
  ports:
    - port: 80
    targetPort: 3000
    nodePort: 30080
